{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test:parser": "tsx src/lib/__tests__/localParser.test.ts",
    "test": "tsx src/lib/__tests__/localParser.test.ts && tsx src/lib/__tests__/aiAgent.test.ts",
    "test:agent": "tsx src/lib/__tests__/aiAgent.test.ts",
    "build:apk": "bash ./scripts/build-apk.sh",
    "build:apk:dev": "VITE_API_BASE_URL=http://10.0.2.2:3000 bash ./scripts/build-apk.sh"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/share": "^8.0.1",
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.15.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "styled-components": "^6.4.3",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "cloudflared": "^0.7.1",
    "esbuild": "^0.25.0",
    "localtunnel": "^2.0.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "tunnelmole": "^2.4.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
