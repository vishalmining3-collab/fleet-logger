# ─── PRIMARY: NVIDIA NIM (faster, much higher quotas) ────────────────────────────
# Get a free key at https://build.nvidia.com (then "Get API Key")
# Without a key the app falls back to Gemini automatically.
NVIDIA_API_KEY=""

# Override NIM models (optional, defaults shown)
NVIDIA_CHAT_MODEL="meta/llama-3.1-70b-instruct"
NVIDIA_ASR_MODEL="nvidia/parakeet-ctc-1.1b-asr"

# ─── FALLBACK: Google Gemini ─────────────────────────────────────────────────────
# Only used when NVIDIA_API_KEY is missing or returns an error.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# ─── OPTIONAL: Supabase cloud sync ───────────────────────────────────────────────
# If set, the server uses Supabase Postgres instead of local data/entries.json.
# Run the SQL from security_spec.md / PRD section 6 in the Supabase SQL editor.
SUPABASE_URL=""
SUPABASE_KEY=""

# ─── OPTIONAL: App URL (only used for self-referential links) ────────────────────
APP_URL="http://localhost:3000"
